<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://com.insurance.policy.core.view.policy/policyDetailView.title"
      focusComponent="form">
    <data>
        <instance id="policyDc"
                  class="com.insurance.policy.core.entity.Policy">
            <fetchPlan extends="_base"/>
            <loader id="policyDl"/>
        </instance>
        <instance id="partnerDc" class="com.insurance.partner.api.dto.PartnerDto" />
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <hbox>
            <details themeNames="filled" summaryText="msg://com.insurance.policy.core.view.policy/policyDetails" opened="true" width="100%">
            <formLayout id="form" dataContainer="policyDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                    <responsiveStep minWidth="40em" columns="2"/>
                </responsiveSteps>
                <select id="insuranceProductField" property="insuranceProduct" readOnly="true"/>
                <textField id="policyNoField" property="policyNo" readOnly="true"/>
                <datePicker id="coverageStartField" property="coverageStart" readOnly="true"/>
                <datePicker id="coverageEndField" property="coverageEnd" readOnly="true"/>
                <textField id="premiumField" property="premium" readOnly="true"/>
                <select id="paymentFrequencyField" property="paymentFrequency" readOnly="true"/>
            </formLayout>
            </details>
            <vbox padding="false" width="300px">
                <details themeNames="filled" summaryText="msg://com.insurance.policy.core.view.policy/policyHolder" opened="true" width="100%">
                    <formLayout id="partnerForm" dataContainer="partnerDc" width="100%">
                        <textField id="partnerNoField" property="partnerNo" readOnly="true"/>
                        <textField id="firstNameField" property="firstName" readOnly="true"/>
                        <textField id="lastNameField" property="lastName" readOnly="true"/>
                    </formLayout>
                </details>
                <details themeNames="filled" summaryText="msg://com.insurance.policy.core.view.policy/accountBalance" opened="true" width="100%">
                    <vbox width="100%">
                        <datePicker id="accountBalanceEffectiveDatePicker" label="msg://com.insurance.policy.core.view.policy/effectiveDate"/>
                        <textField id="accountBalanceResult" label="msg://com.insurance.policy.core.view.policy/accountBalance" readOnly="true">
                            <suffix>
                                <span text="msg://com.insurance.policy.core.view.policy/eur"/>
                            </suffix>
                        </textField>
                    </vbox>
                </details>
            </vbox>
        </hbox>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
