<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <include file="/io/jmix/data/liquibase/changelog.xml"/>

    <changeSet id="1" author="app">
        <createTable tableName="POLICY_POLICY">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_POLICY_POLICY"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="timestamp with time zone"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="timestamp with time zone"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="timestamp with time zone"/>
            <column name="PARTNER_NO" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="INSURANCE_PRODUCT" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="POLICY_NO" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="IDX_POLICY_POLICY_NO"/>
            </column>
            <column name="COVERAGE_START" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="COVERAGE_END" type="DATE"/>
            <column name="PREMIUM" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="PAYMENT_FREQUENCY" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>