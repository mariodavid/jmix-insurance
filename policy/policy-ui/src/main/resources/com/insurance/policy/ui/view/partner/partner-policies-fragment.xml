<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data>
        <collection id="policiesDc"
                    class="com.insurance.policy.api.dto.PartnerPolicySummaryDto"/>
    </data>
    <content>
        <vbox id="root" width="100%" padding="false">
            <dataGrid id="policiesGrid"
                      dataContainer="policiesDc"
                      width="100%"
                      allRowsVisible="true"
                      classNames="theme-grid">
                <columns>
                    <column property="policyNo"
                            header="msg://com.insurance.policy.ui.view.partner/policyNo.label"/>
                    <column key="status"
                            header="msg://com.insurance.policy.ui.view.partner/status.label"/>
                </columns>
            </dataGrid>
        </vbox>
    </content>
</fragment>
