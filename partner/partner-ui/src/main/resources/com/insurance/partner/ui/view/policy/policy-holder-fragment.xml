<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data>
        <instance id="partnerDc"
                  class="com.insurance.partner.api.dto.PartnerDto"/>
    </data>
    <content>
        <vbox id="root" width="100%" padding="false">
            <formLayout dataContainer="partnerDc" width="100%">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                </responsiveSteps>
                <textField id="partnerNoField"
                           property="partnerNo"
                           label="msg://com.insurance.partner.ui.view.policy/partnerNo.label"
                           readOnly="true"/>
                <textField id="firstNameField"
                           property="firstName"
                           label="msg://com.insurance.partner.ui.view.policy/firstName.label"
                           readOnly="true"/>
                <textField id="lastNameField"
                           property="lastName"
                           label="msg://com.insurance.partner.ui.view.policy/lastName.label"
                           readOnly="true"/>
            </formLayout>
        </vbox>
    </content>
</fragment>
