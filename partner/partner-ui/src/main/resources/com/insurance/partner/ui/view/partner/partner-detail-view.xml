<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://partnerDetailView.title"
      focusComponent="form">
    <data>
        <instance id="partnerDc" class="com.insurance.partner.core.entity.Partner">
            <fetchPlan extends="_base"/>
            <loader id="partnerDl"/>
        </instance>
        <keyValueCollection id="policiesDc">
            <properties>
                <property name="policyNo" class="java.lang.String"/>
                <property name="coverageEnd" class="java.time.LocalDate"/>
            </properties>
            <loader id="policiesDl">
                <query><![CDATA[select e.policyNo, e.coverageEnd from policy_Policy e where e.partnerNo = :partnerNo]]></query>
            </loader>
        </keyValueCollection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <hbox width="100%" gap="true">
            <!-- Left Column: Partner Details -->
            <details id="partnerDetails" summaryText="msg://partnerDetailsCard.title" width="55%" themeNames="filled" opened="true">
                <formLayout id="form" dataContainer="partnerDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="30em" columns="2"/>
                    </responsiveSteps>
                    <textField id="partnerNoField" property="partnerNo" readOnly="true"/>
                    <textField id="firstNameField" property="firstName"/>
                    <textField id="lastNameField" property="lastName"/>
                </formLayout>
            </details>

            <!-- Right Column: Policies & Account -->
            <vbox padding="false" width="45%" height="100%" expand="policiesDetails">
                <!-- Policies Card -->
                <details id="policiesDetails" summaryText="msg://policiesCard.title" width="100%" themeNames="filled" opened="true" height="100%">
                    <dataGrid id="policiesGrid" dataContainer="policiesDc" width="100%" height="100%" classNames="theme-grid">
                        <columns>
                            <column property="policyNo" header="msg://policyNo.label"/>
                            <column key="status" header="msg://status.label"/>
                        </columns>
                    </dataGrid>
                </details>

                <!-- Account Card -->
                <details id="accountDetails" summaryText="msg://accountCard.title" width="100%" themeNames="filled" opened="true">
                    <formLayout>
                        <responsiveSteps>
                            <responsiveStep minWidth="0" columns="1"/>
                        </responsiveSteps>
                        <textField id="accountNoField" label="msg://accountNo.label" readOnly="true"/>
                        <textField id="balanceField" label="msg://balance.label" readOnly="true"/>
                    </formLayout>
                </details>
            </vbox>
        </hbox>

        <hbox id="detailActions" classNames="mt-m">
            <button id="saveAndCloseButton" action="saveCloseAction" themeNames="primary"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
