<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://partnerListView.title"
      focusComponent="partnersDataGrid">
    <data>
        <collection id="partnersDc" class="com.insurance.partner.core.entity.Partner">
            <fetchPlan extends="_base"/>
            <loader id="partnersDl" readOnly="true">
                <query><![CDATA[select e from partner_Partner e order by e.partnerNo]]></query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <layout>
        <genericFilter id="genericFilter" dataLoader="partnersDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel align-items-center mb-s">
            <button id="createButton" action="partnersDataGrid.create" themeNames="primary"/>
            <button id="editButton" action="partnersDataGrid.edit"/>
            <button id="removeButton" action="partnersDataGrid.remove"/>
            <simplePagination id="pagination" dataLoader="partnersDl" classNames="ms-auto"/>
        </hbox>
        <dataGrid id="partnersDataGrid" dataContainer="partnersDc" width="100%" height="100%" classNames="theme-grid">
            <actions>
                <action id="create" type="list_create"/>
                <action id="edit" type="list_edit"/>
                <action id="remove" type="list_remove"/>
            </actions>
            <columns>
                <column property="partnerNo"/>
                <column property="firstName"/>
                <column property="lastName"/>
            </columns>
        </dataGrid>
    </layout>
</view>
