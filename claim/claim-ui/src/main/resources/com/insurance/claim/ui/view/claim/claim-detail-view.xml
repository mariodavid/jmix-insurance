<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://com.insurance.claim.ui.view.claim/claimDetailView.title"
      focusComponent="form">
    <data>
        <instance id="claimDc"
                  class="com.insurance.claim.core.entity.Claim">
            <fetchPlan extends="_base">
                <property name="reserves" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="claimDl"/>
            <collection id="reservesDc" property="reserves"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout height="100%" expand="scrollBox">
        <vbox id="scrollBox" padding="false" width="100%">
            <details themeNames="filled" summaryText="msg://com.insurance.claim.ui.view.claim/claimDetails" opened="true" width="100%">
                <formLayout id="form" dataContainer="claimDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>
                    <entityComboBox id="policyComboBox"
                                    label="msg://com.insurance.claim.ui.view.claim/policyComboBox.label"
                                    metaClass="policy_api_PolicyDto"
                                    colspan="2">
                        <actions>
                            <action id="entityClear" type="entity_clear"/>
                        </actions>
                    </entityComboBox>
                    <datePicker id="reportDateField" property="reportDate"/>
                    <datePicker id="incidentDateField" property="incidentDate"/>
                    <comboBox id="claimStatusField" property="claimStatus"/>
                    <textField id="expectedClaimAmountField" property="expectedClaimAmount"/>
                    <textArea id="descriptionField" property="description" colspan="2"/>
                </formLayout>
            </details>
            <details themeNames="filled" summaryText="msg://com.insurance.claim.ui.view.claim/reserves" opened="true" width="100%">
                <vbox padding="false" width="100%">
                    <hbox id="reserveButtonsPanel" classNames="buttons-panel">
                        <button id="reserveCreateButton" action="reservesDataGrid.list_create"/>
                        <button id="reserveEditButton" action="reservesDataGrid.list_edit"/>
                        <button id="reserveRemoveButton" action="reservesDataGrid.list_remove"/>
                        <button id="reserveApproveButton" action="reservesDataGrid.approve"/>
                    </hbox>
                    <dataGrid id="reservesDataGrid"
                              width="100%"
                              minHeight="10em"
                              dataContainer="reservesDc"
                              columnReorderingAllowed="true">
                        <actions>
                            <action id="list_create" type="list_create"/>
                            <action id="list_edit" type="list_edit"/>
                            <action id="list_remove" type="list_remove"/>
                            <action id="approve" text="msg://com.insurance.claim.ui.view.claim/approveReserve"/>
                        </actions>
                        <columns resizable="true">
                            <column property="reserveType"/>
                            <column property="reserveStatus"/>
                            <column property="reserveAmount"/>
                            <column property="reason"/>
                        </columns>
                    </dataGrid>
                </vbox>
            </details>
        </vbox>
        <hbox id="detailActions" classNames="mt-m">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
