<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<mainView xmlns="http://jmix.io/schema/flowui/main-view"
          title="msg://MainView.title">
    <actions>
        <action id="logoutAction" text="msg:///actions.logout.text" type="logout"/>
    </actions>
    <appLayout classNames="jmix-main-view-top-menu-app-layout">
        <navigationBar>
            <vbox id="navigationBarBox"
                  classNames="jmix-main-view-top-menu-navigation-bar-box">
                <header id="navigationHeader"
                        classNames="jmix-main-view-top-menu-header">
                    <anchor href="."
                            classNames="jmix-main-view-top-menu-logo-container">
                        <div classNames="app-logo-box">
                            <span classNames="app-logo-glyph"/>
                        </div>
                        <span text="msg://applicationTitle.text"
                              classNames="jmix-main-view-top-menu-logo-label"/>
                    </anchor>
                    <nav id="navigation"
                         classNames="jmix-main-view-top-menu-navigation">
                        <horizontalMenu id="horizontalMenu"
                                        tabNavigation="true"
                                        width="100%"/>
                    </nav>
                    <userMenu id="userMenu"
                              themeNames="tertiary" classNames="ms-auto me-m">
                        <items>
                            <separator/>
                            <actionItem id="substituteUserMenuItem"
                                        themeNames="non-checkable">
                                <action id="substituteUserAction" type="sec_userMenuSubstituteUser"/>
                            </actionItem>
                            <separator/>
                            <actionItem id="logoutMenuItem" ref="logoutAction"
                                        themeNames="non-checkable"/>
                        </items>
                    </userMenu>
                </header>
                <hbox id="viewHeaderBox"
                      classNames="jmix-main-view-top-menu-view-header-box"
                      alignItems="CENTER">
                    <div id="viewHeaderIconContainer"
                         classNames="view-header-icon-container"
                         visible="false"/>
                    <h1 id="viewTitle"
                        classNames="jmix-main-view-top-menu-view-title"/>
                </hbox>
            </vbox>
        </navigationBar>
        <initialLayout id="initialLayout"
                       alignItems="CENTER" justifyContent="CENTER"
                       width="100%" height="100%">
            <vbox alignItems="CENTER" maxWidth="40em" spacing="true">
                <div classNames="app-logo-box welcome-logo-box">
                    <span classNames="app-logo-glyph welcome-logo-glyph"/>
                </div>
                <h1 text="msg://applicationTitle.text" classNames="welcome-title"/>
            </vbox>
            <!--
                This is the work area - central part of the view.
                Put your components here.
            -->
        </initialLayout>
    </appLayout>
</mainView>